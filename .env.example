# Supabase Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# Public Supabase credentials (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret credentials (NEVER expose in frontend)
# Only used in server-side operations (API routes, middleware)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
CRON_SECRET=replace-with-at-least-32-random-characters
RESEND_API_KEY=re_your_server_only_resend_key
EMAIL_FROM="Rapid Rise AI <team@rapidriseai.com>"
# Marketing website origin — used to build referral links that resolve on the
# public site (e.g. https://www.rapidriseai.com/r/<code>/<token>).
NEXT_PUBLIC_SITE_URL=https://www.rapidriseai.com
# The PORTAL's own origin — used for auth callbacks (email verification +
# password reset). Set this to where THIS app is deployed (e.g.
# https://affiliates.rapidriseai.com). If unset, the request's forwarded host is
# used. It must differ from NEXT_PUBLIC_SITE_URL when the portal and marketing
# site are on different domains. Add "<this>/auth/callback" to the Supabase Auth
# "Redirect URLs" allowlist, or verification/reset links will be rejected.
NEXT_PUBLIC_PORTAL_URL=https://affiliates.rapidriseai.com

# Rate limiting (Upstash Redis REST). Optional but recommended in production.
# Without these, rate limiting fails open (requests are allowed) and only
# Supabase Auth's built-in throttling applies. Create a free database at
# https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
